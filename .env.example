# Canonical site URL for Open Graph / metadataBase (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://your-gateway.example.com

# --- Contact + subscribe forms (server-side email delivery) ---
# The forms POST to /api/contact, which sends email via Resend's REST API.
# Set up: create a key at https://resend.com and verify the masxai.com domain.
# These are SECRETS — do not commit real values here:
#   - Local dev:  add to .dev.vars
#   - Production: wrangler secret put RESEND_API_KEY
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides (defaults shown):
# CONTACT_TO=admin@masxai.com
# CONTACT_FROM=MASX AI Website <no-reply@masxai.com>
